# Скопируй этот файл в .env и впиши свои значения.
# .env в git НЕ попадает (см. .gitignore). Сюда токены НЕ пишем.

# Токен бота от BotFather (используй НОВЫЙ, перевыпущенный через /revoke)
BOT_TOKEN=

# Твой telegram_id (узнать у @userinfobot) — единственный, кому доступна
# команда /provider (меняет LLM-каскад глобально для всего бота).
ADMIN_TELEGRAM_ID=

# ── LLM-провайдеры (каскад: Gemini → Groq → OpenRouter) ──────────────────────
# Достаточно хотя бы одного ключа, но лучше задать несколько — тогда при лимите
# одного провайдера бот автоматически переключится на следующий.

# Gemini — основной. Ключ из https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Прокси ТОЛЬКО для Gemini — нужен там, где его API заблокирован по гео (напр. РФ).
# Формат: http://HOST:PORT или socks5://HOST:PORT. Пусто = ходить напрямую.
# Пример для локального VPN-клиента (v2rayN и т.п.): http://127.0.0.1:10809
GEMINI_PROXY=

# Groq — запасной 1. Ключ из https://console.groq.com/keys
# (LLM_API_KEY поддерживается как старый алиас GROQ_API_KEY)
GROQ_API_KEY=

# OpenRouter — запасной 2. Ключ из https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Необязательные настройки ─────────────────────────────────────────────────
# Порог накопления сообщений для авто-пересборки карточек (по умолчанию 50)
# REBUILD_THRESHOLD=50
# Размер выборки сообщений для LLM-анализа (по умолчанию 150)
# SAMPLE_SIZE=150

# ── Подписка (Tribute) ────────────────────────────────────────────────────────
# Приватный канал-пропуск: Tribute добавляет/убирает участников по оплате,
# бот только проверяет членство. ID канала (вида -100...) — Telegram Desktop:
# правая кнопка по каналу → Copy Link/ID, или через @userinfobot переслав пост
# из канала. Бота нужно добавить в канал АДМИНОМ, иначе get_chat_member не сработает.
PREMIUM_CHANNEL_ID=
# Ссылка на оформление подписки (со страницы канала в Tribute) — показываем в пейволле.
PREMIUM_SUBSCRIBE_URL=
# Бесплатных попыток (Переписать/Ответить за меня/По скриншоту) до пейволла.
# FREE_TRIAL_REQUESTS=5
# Кэш проверки членства в канале, сек — чтобы не дёргать Telegram API на каждое сообщение.
# PREMIUM_CACHE_TTL=300
